# Optional SMTP settings for real email delivery.
# Leave blank to use the built-in local debug email service.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
MAIL_FROM="Formula 1 <your-email@example.com>"
# Enable maintenance mode by setting this to true or creating a .maintenance file.
MAINTENANCE_MODE=false
# Set to true to indicate that the admin is online.
ADMIN_ONLINE=false
